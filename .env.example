# Rainbow-Docs Configuration

# 数据库配置
DATABASE_URL=127.0.0.1:8686
DATABASE_USER=root
DATABASE_PASS=root
DATABASE_NAMESPACE=docs
DATABASE_DB=main
DATABASE_CONNECTION_TIMEOUT=30
DATABASE_MAX_CONNECTIONS=10

# JWT配置 (必需)
# JWT_SECRET 生产必须替换：openssl rand -base64 64
JWT_SECRET=8A5xMSMdwqdMXmEHBo2zByyRSFJFsdSYKNEWY0n9f2E=
# JWT_EXPIRATION 单位秒：86400=24小时(生产推荐) 31536000=365天(AI 长期接入用)
JWT_EXPIRATION=86400

# Rainbow-Auth 集成配置
RAINBOW_AUTH_URL=http://localhost:8080
RAINBOW_AUTH_INTEGRATION=true

# 服务器配置
HOST=0.0.0.0
PORT=3000
APP_URL=http://localhost:3000

# CORS 白名单（生产必填，逗号分隔；不设/留空 = 允许所有，仅限开发）
# CORS_ALLOWED_ORIGINS=https://docs.your-domain.com,https://your-ai-app.com

# 功能开关
ENABLE_PDF_EXPORT=false
ENABLE_NOTIFICATIONS=true
ENABLE_COMMENTS=true
ENABLE_VERSIONING=true

# 可选功能配置
# SMTP配置 (如果启用通知)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=your-username
# SMTP_PASSWORD=your-password
# SMTP_FROM=noreply@your-domain.com